{
  "name": "RStudio Codespace",
  "image": "rocker/rstudio:latest",

  // Ensure RStudio starts automatically when the codespace boots
  "postStartCommand": "sudo rstudio-server start || true",

  // Fix permissions so the 'rstudio' user can access your GitHub repo files
  "postCreateCommand": "sudo chmod -R 777 /workspaces" && ln -s /workspaces/$(basename $GITHUB_WORKSPACE) /home/rstudio/project || true" ,

  "containerEnv": {
    // Bypass the RStudio login screen since Codespaces handle authentication
    "DISABLE_AUTH": "true"
  },

  "forwardPorts": [8787],

  "portsAttributes": {
    "8787": {
      "label": "RStudio Server",
      "onAutoForward": "openPreview"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "REditorSupport.r" // Optional: Adds R support if you use the VS Code editor too
      ]
    }
  }
}